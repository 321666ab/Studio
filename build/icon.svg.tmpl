<svg width="1024" height="1024" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg">
  <!--
    Studio app icon — liquid glass treatment over the original artwork.
    The artwork layer is injected from build/icon-artwork.png by
    script/generate_icon.sh (placeholder: __ARTWORK_B64__). Do not edit the
    generated build/icon.svg; edit this template instead.
  -->
  <defs>
    <radialGradient id="topGlow" cx="0.32" cy="0.06" r="0.9">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.42"/>
      <stop offset="0.32" stop-color="#ffffff" stop-opacity="0.10"/>
      <stop offset="1" stop-color="#ffffff" stop-opacity="0"/>
    </radialGradient>
    <linearGradient id="sheen" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.22"/>
      <stop offset="0.55" stop-color="#ffffff" stop-opacity="0.06"/>
      <stop offset="1" stop-color="#ffffff" stop-opacity="0"/>
    </linearGradient>
    <linearGradient id="bottomShade" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#02102e" stop-opacity="0"/>
      <stop offset="1" stop-color="#02102e" stop-opacity="0.34"/>
    </linearGradient>
    <linearGradient id="rim" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#ffffff" stop-opacity="0.75"/>
      <stop offset="0.25" stop-color="#ffffff" stop-opacity="0.25"/>
      <stop offset="1" stop-color="#ffffff" stop-opacity="0.14"/>
    </linearGradient>
    <filter id="iconShadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="20" stdDeviation="26" flood-color="#04143a" flood-opacity="0.45"/>
    </filter>
    <clipPath id="squircle">
      <rect x="96" y="96" width="832" height="832" rx="188"/>
    </clipPath>
  </defs>

  <!-- Base plate (also the fallback color behind the artwork) -->
  <g filter="url(#iconShadow)">
    <rect x="96" y="96" width="832" height="832" rx="188" fill="#3a6f9b"/>
  </g>

  <g clip-path="url(#squircle)">
    <!-- Original artwork, slightly overscanned so its own baked corners crop away -->
    <image x="80" y="80" width="864" height="864" preserveAspectRatio="xMidYMid slice"
      href="data:image/png;base64,__ARTWORK_B64__"/>

    <!-- Liquid glass layers -->
    <rect x="96" y="96" width="832" height="832" fill="url(#topGlow)"/>
    <rect x="96" y="96" width="832" height="360" fill="url(#sheen)"/>
    <rect x="96" y="656" width="832" height="272" fill="url(#bottomShade)"/>
    <rect x="101" y="101" width="822" height="822" rx="184" fill="none"
      stroke="url(#rim)" stroke-width="3"/>
    <!-- Specular arc along the top edge -->
    <path d="M214 128 q298 -52 596 0" fill="none" stroke="#ffffff" stroke-opacity="0.55"
      stroke-width="6" stroke-linecap="round"/>
  </g>
</svg>
